<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>だぁーうぃん | Community Manager / 活動名</title>
<link href="https://fonts.googleapis.com/css2?family=M+PLUS+1p:wght@300;400;500;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --navy:   #1E2761;
    --mid:    #3A4A8A;
    --accent: #4F8EF7;
    --ice:    #D6E4FF;
    --white:  #FFFFFF;
    --dark:   #12183A;
    --gray:   #8898BB;
    --light:  #F4F7FF;
    --card:   #FFFFFF;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'M PLUS 1p', sans-serif;
    background: var(--light);
    color: var(--dark);
    overflow-x: hidden;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(18, 24, 58, 0.92);
    backdrop-filter: blur(12px);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 2rem; height: 60px;
    border-bottom: 1px solid rgba(79,142,247,0.2);
  }
  .nav-logo {
    font-family: 'M PLUS 1p', sans-serif;
    font-size: 1.2rem; color: var(--white); font-weight: 700;
    letter-spacing: 0.05em;
  }
  .nav-logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    color: var(--gray); text-decoration: none; font-size: 0.82rem;
    font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }

  /* ─── HERO ─── */
  #hero {
    min-height: 100vh;
    background: var(--navy);
    display: flex; align-items: center;
    position: relative; overflow: hidden;
    padding: 80px 0 0;
  }
  .hero-bg-circle {
    position: absolute; border-radius: 50%;
    background: var(--mid); opacity: 0.3;
  }
  .hero-bg-circle.c1 { width: 500px; height: 500px; top: -100px; right: -80px; }
  .hero-bg-circle.c2 { width: 300px; height: 300px; bottom: 60px; right: 180px; background: var(--accent); opacity: 0.12; }
  .hero-bg-circle.c3 { width: 200px; height: 200px; bottom: -60px; left: -40px; background: var(--accent); opacity: 0.08; }

  .hero-inner {
    max-width: 1100px; margin: 0 auto; padding: 0 2rem;
    display: grid; grid-template-columns: 1fr 340px; gap: 4rem;
    align-items: center; width: 100%;
  }
  .hero-tag {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.18em;
    color: var(--accent); text-transform: uppercase; margin-bottom: 1rem;
    display: flex; align-items: center; gap: 0.6rem;
  }
  .hero-tag::before {
    content: ''; display: block; width: 28px; height: 2px; background: var(--accent);
  }
  .hero-name {
    font-family: 'M PLUS 1p', sans-serif;
    font-size: clamp(3rem, 6vw, 5rem);
    color: var(--white); line-height: 1.1; margin-bottom: 0.6rem;
    animation: fadeUp 0.8s ease both;
  }
  .hero-en {
    font-size: 0.9rem; color: var(--gray); letter-spacing: 0.12em;
    margin-bottom: 1.8rem; font-style: italic;
  }
  .hero-catch {
    font-size: clamp(1rem, 2vw, 1.25rem); color: var(--ice);
    line-height: 1.7; margin-bottom: 2.5rem;
    animation: fadeUp 0.8s 0.1s ease both;
  }
  .hero-tags {
    display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2.5rem;
    animation: fadeUp 0.8s 0.2s ease both;
  }
  .hero-tag-badge {
    background: rgba(79,142,247,0.15); border: 1px solid rgba(79,142,247,0.4);
    color: var(--ice); font-size: 0.78rem; padding: 0.3rem 0.9rem;
    border-radius: 999px; font-weight: 500;
  }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 0.6rem;
    background: var(--accent); color: var(--white);
    padding: 0.85rem 2rem; border-radius: 999px;
    text-decoration: none; font-weight: 700; font-size: 0.9rem;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(79,142,247,0.35);
    animation: fadeUp 0.8s 0.3s ease both;
  }
  .hero-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(79,142,247,0.45); }

  .hero-avatar-wrap {
    position: relative; animation: fadeUp 0.8s 0.15s ease both;
  }
  .hero-avatar-ring {
    width: 280px; height: 280px; border-radius: 50%;
    border: 3px solid var(--accent);
    padding: 6px; margin: 0 auto;
    background: linear-gradient(135deg, var(--mid), var(--navy));
    box-shadow: 0 0 60px rgba(79,142,247,0.25);
  }
  .hero-avatar-ring img {
    width: 100%; height: 100%; border-radius: 50%; object-fit: cover;
  }
  .hero-stat-chip {
    position: absolute; background: var(--white);
    border-radius: 12px; padding: 0.6rem 1rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.18);
    font-size: 0.75rem; font-weight: 700; color: var(--navy);
    white-space: nowrap;
  }
  .hero-stat-chip .num { font-size: 1.2rem; color: var(--accent); display: block; }
  .chip-1 { bottom: 30px; left: -20px; }
  .chip-2 { top: 20px; right: -10px; }

  /* ─── SECTIONS ─── */
  section { padding: 6rem 1.5rem; }

  .section-inner { max-width: 1100px; margin: 0 auto; }

  .section-label {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.2em;
    color: var(--accent); text-transform: uppercase;
    display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.8rem;
  }
  .section-label::before { content: ''; display: block; width: 24px; height: 2px; background: var(--accent); }

  .section-title {
    font-family: 'M PLUS 1p', sans-serif;
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    color: var(--navy); margin-bottom: 3rem; line-height: 1.2;
  }

  /* ─── ABOUT ─── */
  #about { background: var(--white); }
  .about-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem;
  }
  .about-card {
    background: var(--light); border-radius: 16px;
    padding: 1.8rem 1.5rem;
    border-top: 3px solid var(--accent);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .about-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(79,142,247,0.12); }
  .about-card-icon {
    width: 44px; height: 44px; border-radius: 10px;
    background: var(--navy); display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem; margin-bottom: 1rem;
  }
  .about-card h3 { font-size: 0.95rem; color: var(--navy); font-weight: 700; margin-bottom: 0.5rem; }
  .about-card p { font-size: 0.85rem; color: #555; line-height: 1.7; }

  /* ─── SKILLS ─── */
  #skills { background: var(--light); }
  .skills-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
  }
  .skill-card {
    background: var(--white); border-radius: 16px; padding: 1.8rem;
    border-left: 4px solid var(--accent);
    box-shadow: 0 2px 16px rgba(30,39,97,0.06);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .skill-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(79,142,247,0.14); }
  .skill-header {
    display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1rem;
  }
  .skill-icon {
    width: 40px; height: 40px; border-radius: 10px;
    background: var(--ice); display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; flex-shrink: 0;
  }
  .skill-card h3 { font-size: 1rem; color: var(--navy); font-weight: 700; }
  .skill-card ul { list-style: none; }
  .skill-card ul li {
    font-size: 0.85rem; color: #555; padding: 0.3rem 0;
    display: flex; align-items: flex-start; gap: 0.5rem; line-height: 1.5;
  }
  .skill-card ul li::before { content: '›'; color: var(--accent); font-weight: 700; flex-shrink: 0; }

  /* ─── WORKS ─── */
  #works { background: var(--navy); }
  #works .section-title { color: var(--white); }
  .works-client {
    font-size: 0.82rem; color: var(--gray); margin-bottom: 2rem; font-style: italic;
  }
  .works-list { display: flex; flex-direction: column; gap: 1.2rem; }
  .work-card {
    background: rgba(255,255,255,0.06); border-radius: 16px;
    border: 1px solid rgba(79,142,247,0.2);
    padding: 1.5rem 1.8rem;
    display: grid; grid-template-columns: 60px 1fr auto;
    gap: 1.5rem; align-items: center;
    transition: background 0.2s, border-color 0.2s;
  }
  .work-card:hover { background: rgba(79,142,247,0.1); border-color: rgba(79,142,247,0.5); }
  .work-num {
    font-family: 'M PLUS 1p', sans-serif;
    font-size: 2rem; color: var(--accent); font-weight: 700; text-align: center;
  }
  .work-genre {
    display: inline-block; font-size: 0.7rem; font-weight: 700;
    background: rgba(79,142,247,0.2); color: var(--ice);
    padding: 0.2rem 0.7rem; border-radius: 999px; margin-bottom: 0.4rem;
  }
  .work-title { font-size: 1rem; color: var(--white); font-weight: 700; margin-bottom: 0.3rem; }
  .work-tasks { font-size: 0.78rem; color: var(--gray); }
  .work-period {
    font-size: 0.78rem; color: var(--accent); font-weight: 700;
    white-space: nowrap; text-align: right;
  }
  .works-note { font-size: 0.75rem; color: var(--gray); margin-top: 1.5rem; font-style: italic; }

  /* ─── FOR YOU ─── */
  #foryou { background: var(--white); }
  .foryou-list { display: flex; flex-direction: column; gap: 1rem; }
  .foryou-item {
    border-radius: 12px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(30,39,97,0.07);
  }
  .foryou-q {
    background: var(--ice); padding: 1rem 1.2rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .foryou-badge {
    width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem; font-weight: 700;
  }
  .foryou-badge.q { background: var(--accent); color: var(--white); }
  .foryou-badge.a { background: var(--navy); color: var(--accent); }
  .foryou-q p { font-size: 0.92rem; color: var(--navy); font-weight: 700; }
  .foryou-a {
    background: var(--light); padding: 0.9rem 1.2rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .foryou-a p { font-size: 0.88rem; color: #444; }

  /* ─── CONTACT ─── */
  #contact {
    background: linear-gradient(135deg, var(--navy) 0%, var(--mid) 100%);
    text-align: center; padding: 5rem 1.5rem;
    position: relative; overflow: hidden;
  }
  #contact::before {
    content: ''; position: absolute; top: -120px; right: -100px;
    width: 400px; height: 400px; border-radius: 50%;
    background: rgba(79,142,247,0.12);
  }
  #contact::after {
    content: ''; position: absolute; bottom: -80px; left: -60px;
    width: 280px; height: 280px; border-radius: 50%;
    background: rgba(79,142,247,0.08);
  }
  .contact-inner { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }
  .contact-avatar {
    width: 90px; height: 90px; border-radius: 50%;
    border: 3px solid var(--accent); margin: 0 auto 1.5rem;
    object-fit: cover;
    box-shadow: 0 0 30px rgba(79,142,247,0.3);
  }
  #contact .section-label { justify-content: center; }
  #contact .section-label::before { display: none; }
  #contact h2 {
    font-family: 'M PLUS 1p', sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem); color: var(--white);
    margin-bottom: 0.8rem;
  }
  #contact p { font-size: 0.9rem; color: var(--ice); margin-bottom: 2.5rem; line-height: 1.7; }

  .contact-links { display: flex; flex-direction: column; gap: 0.9rem; align-items: center; }
  .contact-link {
    display: flex; align-items: center; gap: 1rem;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    border-radius: 12px; padding: 0.9rem 1.5rem; width: 100%; max-width: 380px;
    text-decoration: none; color: var(--white);
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }
  .contact-link:hover { background: rgba(79,142,247,0.2); border-color: var(--accent); transform: translateX(4px); }
  .contact-link-icon {
    width: 36px; height: 36px; border-radius: 8px;
    background: var(--accent); display: flex; align-items: center; justify-content: center;
    font-size: 1rem; flex-shrink: 0;
  }
  .contact-link-label { font-size: 0.75rem; color: var(--gray); }
  .contact-link-val { font-size: 0.95rem; font-weight: 700; }

  /* ─── FOOTER ─── */
  footer {
    background: var(--dark); text-align: center;
    padding: 1.5rem; font-size: 0.75rem; color: var(--gray);
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-in {
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .fade-in.visible { opacity: 1; transform: none; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-avatar-wrap { order: -1; }
    .hero-avatar-ring { width: 200px; height: 200px; }
    .chip-1, .chip-2 { display: none; }
    .hero-tags { justify-content: center; }
    .about-grid { grid-template-columns: 1fr; }
    .skills-grid { grid-template-columns: 1fr; }
    .work-card { grid-template-columns: 50px 1fr; }
    .work-period { grid-column: 1 / -1; text-align: left; }
    nav { padding: 0 1rem; }
    .nav-links { gap: 1rem; }
    .nav-links a { font-size: 0.72rem; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">だぁーうぃん<span>.</span></div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
